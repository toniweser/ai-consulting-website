<script>
  // Generate a tileable noise texture via canvas
  const size = 150;
  const canvas = document.createElement('canvas');
  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext('2d');
  const imageData = ctx.createImageData(size, size);
  const data = imageData.data;
  for (let i = 0; i < data.length; i += 4) {
    const v = Math.random() * 255;
    data[i] = v;
    data[i + 1] = v;
    data[i + 2] = v;
    data[i + 3] = 255;
  }
  ctx.putImageData(imageData, 0, 0);
  const noiseUrl = canvas.toDataURL('image/png');

  // Apply to all grain pseudo-elements via a shared CSS custom property
  document.documentElement.style.setProperty('--grain-url', `url(${noiseUrl})`);
</script>

