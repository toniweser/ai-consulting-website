  /* Shared keyframes */
  @keyframes wander-1 {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(15vw, 10vh); }
    50%  { transform: translate(-10vw, 20vh); }
    75%  { transform: translate(20vw, -5vh); }
    100% { transform: translate(-5vw, 15vh); }
  }
  @keyframes wander-2 {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(-20vw, -15vh); }
    50%  { transform: translate(10vw, 10vh); }
    75%  { transform: translate(-15vw, 20vh); }
    100% { transform: translate(5vw, -10vh); }
  }
  @keyframes wander-3 {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(20vw, -10vh); }
    50%  { transform: translate(-5vw, 15vh); }
    75%  { transform: translate(15vw, 5vh); }
    100% { transform: translate(-10vw, -15vh); }
  }

  /* Nav mock */
  .nav-mock {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 15;
    padding: 1rem 1.5rem;
  }
  .nav-mock .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-mock .brand {
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }
  .nav-mock .links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-mock .link {
    font-size: 0.875rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .nav-mock .link:hover { opacity: 0.8; }
  .nav-mock .cta-nav {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .nav-mock .links { display: none; }
    .theme-hero .blob {
      width: 300px !important;
      height: 300px !important;
    }
  }
</style>

