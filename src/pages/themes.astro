---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Farbvarianten — Hero Section" noindex={true}>

<style is:global>
  /* Shared hero styles */
  .theme-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .theme-hero .blob-wrap {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .theme-hero .blob {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  .theme-hero .content {
    position: relative;
    z-index: 10;
    max-width: 72rem;
    margin: 0 auto;
    padding: 5rem 1.5rem;
  }

  .theme-hero .content .inner {
    max-width: 48rem;
  }

  .theme-hero h1 {
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  .theme-hero p.subtitle {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    line-height: 1.7;
    max-width: 42rem;
    margin-bottom: 2.5rem;
  }

  .theme-hero .cta {
    display: inline-block;
    font-weight: 600;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-size: 1.125rem;
    transition: filter 0.2s, transform 0.2s;
    text-decoration: none;
    color: #fff;
  }
  .theme-hero .cta:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  /* Warm gradient CTA — shared across all variants */
  .cta-warm {
    background: linear-gradient(135deg, #ea580c, #be185d);
  }
  .cta-warm-deep {
    background: linear-gradient(135deg, #c2410c, #9d174d);
  }

  .theme-label {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 20;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    backdrop-filter: blur(8px);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    40%, 60% { opacity: 0; }
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
  }

  /* ── Film grain overlay ── */
  .grain::after,
  .grain-light::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background-image: var(--grain-url, none);
    background-repeat: repeat;
    background-size: 150px 150px;
  }
  .grain::after {
    opacity: 0.06;
    mix-blend-mode: overlay;
  }
  .grain-light::after {
    opacity: 0.025;
    mix-blend-mode: multiply;
  }

  /* ── VARIANT 1: Current Dark ── */
  .theme-dark {
    background-color: #06061a;
  }
  .theme-dark .blob-1 {
    width: 600px; height: 600px;
    top: 10%; left: 20%;
    background: radial-gradient(circle at 30% 40%, #f97316, #ec4899 40%, #a855f7 70%, transparent 100%);
    filter: blur(80px); opacity: 0.45;
    animation: wander-1 20s ease-in-out infinite alternate;
  }
  .theme-dark .blob-2 {
    width: 400px; height: 400px;
    top: 40%; left: 50%;
    background: radial-gradient(circle at 40% 50%, #f97316, #ec4899 50%, #a855f7 80%, transparent 100%);
    filter: blur(60px); opacity: 0.35;
    animation: wander-2 25s ease-in-out infinite alternate;
  }
  .theme-dark .blob-3 {
    width: 600px; height: 600px;
    top: 65%; left: 10%;
    background: radial-gradient(circle at 30% 40%, #f97316, #ec4899 40%, #a855f7 70%, transparent 100%);
    filter: blur(80px); opacity: 0.45;
    animation: wander-3 22s ease-in-out infinite alternate;
  }
  .theme-dark h1 { color: #ffffff; }
  .theme-dark .gradient-text {
    background: linear-gradient(to right, #f97316, #ec4899, #c084fc);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .theme-dark .cursor-blink { background-color: rgba(255,255,255,0.7); }
  .theme-dark p.subtitle { color: #cbd5e1; }
  .theme-dark .theme-label { background: rgba(255,255,255,0.1); color: #e2e8f0; }
  .theme-dark .nav-mock {
    background: rgba(6,6,26,0.8);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    backdrop-filter: blur(12px);
  }
  .theme-dark .nav-mock .brand { color: #fff; }
  .theme-dark .nav-mock .link { color: #cbd5e1; }
  .theme-dark .nav-mock .cta-nav { background: linear-gradient(135deg, #ea580c, #be185d); color: #fff; }

