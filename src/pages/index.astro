---
import Layout from '../layouts/Layout.astro';
import LinkedInIcon from '../components/LinkedInIcon.astro';
---

<Layout title="Braun & Weber - KI-Beratung für Entwicklerteams" description="KI-Workshops für Entwicklerteams: Hands-on an Ihrem Code mit Coding Agents. Kein Vortrag, echte Ergebnisse. Kostenloses Erstgespräch.">

<!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-surface-nav backdrop-blur-md border-b border-divider">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <span class="text-heading font-bold text-lg tracking-tight">Braun & Weber KI-Beratung</span>
      <div class="flex items-center gap-2">
        <div class="hidden md:flex items-center gap-8">
          <a href="#workshop" class="text-sm text-body hover:text-heading transition-colors">Workshop</a>
          <a href="#fuer-wen" class="text-sm text-body hover:text-heading transition-colors">Für wen</a>
          <a href="#ueber-uns" class="text-sm text-body hover:text-heading transition-colors">Über uns</a>
          <a href="#kontakt" class="text-sm font-semibold cta-gradient px-5 py-2 rounded-lg">Kostenloses Erstgespräch</a>
        </div>
        <button id="theme-toggle" class="text-body hover:text-heading p-2 rounded-lg hover:bg-card transition-colors" aria-label="Farbschema wechseln">
          <svg id="icon-sun" class="w-5 h-5" style="display:none" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>
          <svg id="icon-moon" class="w-5 h-5" style="display:none" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
          </svg>
        </button>
        <!-- Mobile: Hamburger -->
        <button id="menu-toggle" class="md:hidden text-heading p-2 -mr-2" aria-label="Menü öffnen">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-divider bg-surface-nav backdrop-blur-md">
      <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
        <a href="#workshop" class="text-body hover:text-heading transition-colors mobile-nav-link">Workshop</a>
        <a href="#fuer-wen" class="text-body hover:text-heading transition-colors mobile-nav-link">Für wen</a>
        <a href="#ueber-uns" class="text-body hover:text-heading transition-colors mobile-nav-link">Über uns</a>
        <a href="#kontakt" class="font-semibold cta-gradient px-5 py-3 rounded-lg text-center mobile-nav-link">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </nav>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => menu.classList.add('hidden'));
    });
  </script>

  <!-- Background Blobs -->
  <div class="blob-container" aria-hidden="true">
    <div class="gradient-blob" id="blob-1"></div>
    <div class="gradient-blob-sm" id="blob-2"></div>
    <div class="gradient-blob" id="blob-3"></div>
  </div>

  <!-- SEKTION 1: Hero -->
  <section class="relative min-h-screen flex items-center pt-20">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-32 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-heading leading-tight tracking-tight mb-10">
          Die größte Revolution seit dem Internet.<br />
          <span class="block relative">
            <span class="invisible grid" aria-hidden="true" id="typewriter-sizer"></span>
            <span class="absolute inset-0"><span class="gradient-text"><span id="typewriter"></span></span><span class="cursor-blink"></span></span>
          </span>
        </h1>

        <script>
          const first = 'Zeit, Ihr Team aufzustellen.';
          const rest = [
            'Wer jetzt einsteigt, erklärt es später den anderen.',
            'KI ist kein Hype. Es ist ein Werkzeug.',
            'Machen Sie Ihr Team zum Vorreiter.',
          ];

          // Shuffle rest randomly
          for (let i = rest.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [rest[i], rest[j]] = [rest[j], rest[i]];
          }

          const phrases = [first, ...rest];
          const el = document.getElementById('typewriter');

          // Reserve height for the tallest phrase so content below never shifts
          const sizer = document.getElementById('typewriter-sizer');
          phrases.forEach((phrase) => {
            const line = document.createElement('span');
            line.style.gridArea = '1 / 1';
            line.textContent = phrase;
            sizer.appendChild(line);
          });
          let phraseIndex = 0;
          let charIndex = 0;
          let deleting = false;

          function tick() {
            const current = phrases[phraseIndex];

            if (!deleting) {
              el.textContent = current.slice(0, charIndex + 1);
              charIndex++;

              if (charIndex === current.length) {
                setTimeout(tick, 2500);
                deleting = true;
                return;
              }
              setTimeout(tick, 55 + Math.random() * 40);
            } else {
              el.textContent = current.slice(0, charIndex);
              charIndex--;

              if (charIndex < 0) {
                deleting = false;
                charIndex = 0;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                setTimeout(tick, 400);
                return;
              }
              setTimeout(tick, 25);
            }
          }

          tick();
        </script>
        <p class="text-lg md:text-xl text-body leading-relaxed max-w-2xl mb-10">
          Coding Agents verändern, wie Software entsteht. Aber nur, wenn das ganze Team mitzieht. Wir zeigen Ihren Entwickler:innen in einem hands-on Workshop, wie sie mit KI-Tools am eigenen Code produktiver arbeiten. Kein Vortrag, kein Spielbeispiel. Echte Arbeit, echte Ergebnisse.
        </p>
        <a
          href="#kontakt"
          class="inline-block cta-gradient font-semibold px-8 py-4 rounded-lg text-lg"
        >
          Kostenloses Erstgespräch vereinbaren
        </a>
      </div>
    </div>
  </section>

  <!-- SEKTION 2: Das Problem -->
  <section class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-heading mb-6">Das kennen Sie: KI im Team, irgendwo zwischen Hype und Stillstand.</h2>
      <p class="text-lg md:text-xl text-body leading-relaxed max-w-3xl mb-16">
        Vielleicht nutzt noch kaum jemand in Ihrem Team KI-Tools. Oder zwei schwören auf Copilot, einer hat Coding Agents entdeckt, und der Rest wartet ab. Das Ergebnis ist dasselbe: Kein einheitlicher Stand, keine Best Practices, kein Fortschritt. Ihr Team verschenkt Potenzial. Nicht weil die Tools fehlen, sondern weil niemand den Einstieg strukturiert hat.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-card border border-divider rounded-2xl p-8 hover:bg-card-hover transition-colors">
          <div class="w-12 h-12 bg-accent-soft rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-heading mb-3">Einheitlicher Stand im Team</h3>
          <p class="text-body leading-relaxed">
            Nicht nur die Early Adopter nutzen KI, sondern das ganze Team. Mit klaren Workflows, abgestimmten Tools und gemeinsamen Spielregeln. Schluss mit "jeder macht irgendwas."
          </p>
        </div>

        <div class="bg-card border border-divider rounded-2xl p-8 hover:bg-card-hover transition-colors">
          <div class="w-12 h-12 bg-accent-soft rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-heading mb-3">Messbar schnellere Ergebnisse</h3>
          <p class="text-body leading-relaxed">
            Code Reviews in Minuten statt Stunden. Tests, die sich selbst schreiben. Dokumentation, die nicht liegen bleibt. Ihre Entwickler arbeiten mit KI so routiniert wie mit Git.
          </p>
        </div>

        <div class="bg-card border border-divider rounded-2xl p-8 hover:bg-card-hover transition-colors">
          <div class="w-12 h-12 bg-accent-soft rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-heading mb-3">Ein Fahrplan, der über den Workshop hinausgeht</h3>
          <p class="text-body leading-relaxed">
            Sie bekommen keinen abstrakten Strategiebericht, sondern einen konkreten Plan: Welche Tools für Ihr Team, welche Workflows für Ihre Codebasis, welche nächsten Schritte. Inklusive Empfehlung, was Sie nicht brauchen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEKTION 3: Wie der Workshop funktioniert -->
  <section id="workshop" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-heading mb-6">Erst verstehen, dann anwenden. An Ihrem Code.</h2>
      <p class="text-lg md:text-xl text-body leading-relaxed max-w-3xl mb-16">
        Wir starten nicht mit einem Tool, sondern mit dem Konzept: Was sind Coding Agents? Wie verändern sie die Art, wie Software entsteht? Welche Tools gibt es, von Cursor über Claude Code bis Codex, und welches passt zu Ihrem Team und Ihrem Stack? Dann wird's konkret.
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-card border border-divider rounded-2xl p-8">
          <p class="text-accent text-sm font-semibold mb-2">Berührungspunkt</p>
          <h3 class="text-lg font-bold text-heading mb-3">Features entwickeln</h3>
          <p class="text-body leading-relaxed">
            Vom Ticket zur Implementierung. Wie ein Agent Kontext aus Jira, Linear oder Ihrem Error-Tracking zieht, Code schreibt und durch Ihre CI/CD-Pipeline bringt. Ohne dass Ihr Team die Kontrolle abgibt.
          </p>
        </div>

        <div class="bg-card border border-divider rounded-2xl p-8">
          <p class="text-accent text-sm font-semibold mb-2">Berührungspunkt</p>
          <h3 class="text-lg font-bold text-heading mb-3">Bugs fixen</h3>
          <p class="text-body leading-relaxed">
            Fehler eingrenzen, Ursache verstehen, Lösung vorschlagen lassen. Und wissen, wann man dem Vorschlag traut und wann nicht.
          </p>
        </div>

        <div class="bg-card border border-divider rounded-2xl p-8">
          <p class="text-accent text-sm font-semibold mb-2">Berührungspunkt</p>
          <h3 class="text-lg font-bold text-heading mb-3">Code Reviews beschleunigen</h3>
          <p class="text-body leading-relaxed">
            KI-gestützte Reviews, die echte Probleme finden, nicht nur Formatierung. Wie Ihr Team schneller reviewed, ohne Qualität zu verlieren.
          </p>
        </div>

        <div class="bg-card border border-divider rounded-2xl p-8">
          <p class="text-accent text-sm font-semibold mb-2">Berührungspunkt</p>
          <h3 class="text-lg font-bold text-heading mb-3">Erst an Beispielen, dann an Ihrem Code</h3>
          <p class="text-body leading-relaxed">
            Wir starten mit klaren, nachvollziehbaren Szenarien. Wenn das Konzept sitzt, schauen wir uns konkrete Fälle aus Ihrem Code an und überlegen gemeinsam, wie sich das mit KI-Tools lösen lässt.
          </p>
        </div>
      </div>

      <div class="bg-card border border-divider rounded-2xl p-8 md:p-10">
        <p class="text-lg text-body leading-relaxed">
          <span class="text-heading font-semibold">Der Inhalt richtet sich nach Ihrem Team.</span> Steht Ihr Team am Anfang, starten wir bei den Grundlagen: Was kann ein Coding Agent, wo sind die Grenzen, wie promptet man richtig. Hat Ihr Team schon Erfahrung, gehen wir in die Tiefe: Vom Ticket über den Agent, der den Code schreibt, den PR erstellt und den Review durchläuft, bis zur Freigabe durch einen Menschen.
        </p>
      </div>
    </div>
  </section>

  <!-- SEKTION 4: Für wen -->
  <section id="fuer-wen" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-heading mb-6">Sie sind hier richtig, wenn...</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        <div class="bg-card border border-divider rounded-2xl p-6 flex gap-4 items-start">
          <span class="text-accent shrink-0">•</span>
          <p class="text-body leading-relaxed">...Sie wissen, dass KI-Tools produktiver machen, aber die konkrete Umsetzung hakt</p>
        </div>
        <div class="bg-card border border-divider rounded-2xl p-6 flex gap-4 items-start">
          <span class="text-accent shrink-0">•</span>
          <p class="text-body leading-relaxed">...Ihre Entwickler am eigenen Code lernen sollen und nicht an trockenen Beispielen</p>
        </div>
        <div class="bg-card border border-divider rounded-2xl p-6 flex gap-4 items-start">
          <span class="text-accent shrink-0">•</span>
          <p class="text-body leading-relaxed">...Sie einen Plan wollen, nicht nur eine Inspiration</p>
        </div>
      </div>

      <div class="bg-card border border-divider rounded-2xl p-8 md:p-10">
        <h3 class="text-lg font-bold text-heading mb-3">Kein Entwicklerteam, aber trotzdem neugierig?</h3>
        <p class="text-body leading-relaxed">
          KI kann auch in Vertrieb, Marketing und Sachbearbeitung enorm helfen. <a href="#kontakt" class="text-accent hover:text-accent-hover underline underline-offset-2">Schreiben Sie uns</a>, wir sagen Ihnen ehrlich, ob und wie wir Ihnen helfen können.
        </p>
      </div>
    </div>
  </section>

  <!-- SEKTION 5: Ablauf -->
  <section class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-heading mb-6">Drei Schritte. Kein Drumherum.</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-card border border-divider rounded-2xl p-8">
          <div class="text-accent text-4xl font-extrabold mb-4">1</div>
          <h3 class="text-lg font-bold text-heading mb-3">Erstgespräch (kostenlos)</h3>
          <p class="text-body leading-relaxed">
            30 Minuten, per Video oder Telefon. Wir lernen Ihr Team kennen: Wie groß, welcher Stack, welche Tools schon im Einsatz, wo es hakt. Danach wissen Sie, ob ein Workshop für Sie sinnvoll ist. Und wir sagen Ihnen ehrlich, wenn nicht.
          </p>
        </div>

        <div class="bg-card border border-divider rounded-2xl p-8">
          <div class="text-accent text-4xl font-extrabold mb-4">2</div>
          <h3 class="text-lg font-bold text-heading mb-3">Workshop, vor Ort oder remote</h3>
          <p class="text-body leading-relaxed">
            Umfang und Tiefe passen wir an Ihr Team an. Hands-on an Ihrem Code, nicht an unserem. Wir richten uns nach Ihrem Stack, Ihrem Tooling und Ihrem Erfahrungslevel. Auch die Skeptiker kommen mit.
          </p>
        </div>

        <div class="bg-card border border-divider rounded-2xl p-8">
          <div class="text-accent text-4xl font-extrabold mb-4">3</div>
          <h3 class="text-lg font-bold text-heading mb-3">Begleitung danach</h3>
          <p class="text-body leading-relaxed">
            Nach dem Workshop lassen wir Sie nicht allein. Ob nächste Schritte, offene Fragen oder Unterstützung bei der Umsetzung: wir bleiben ansprechbar und begleiten Ihr Team so lange, wie es sinnvoll ist.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEKTION 6: Wer wir sind -->
  <section id="ueber-uns" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-heading mb-6">Zwei Entwickler, die jeden Tag mit KI-Tools arbeiten.</h2>
      <p class="text-lg md:text-xl text-body leading-relaxed max-w-3xl mb-16">
        Keine Unternehmensberater, die KI aus der Ferne erklären. Wir schreiben selbst jeden Tag Code mit Coding Agents. Wir wissen, was funktioniert und wo man aufpassen muss. Wir brennen für das Thema und geben dieses Wissen mit Leidenschaft an andere Entwickler:innen und Teams weiter.
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Tobias -->
        <div class="bg-card border border-divider rounded-2xl p-8">
          <div class="flex items-center gap-5 mb-6">
            <img src={`${import.meta.env.BASE_URL}images/tobias-weber.jpg`} alt="Tobias Weber" class="w-20 h-20 rounded-full object-cover shrink-0" />
            <div>
              <h3 class="text-xl font-bold text-heading flex items-center gap-2">Tobias Weber <a href="https://www.linkedin.com/in/tobias-weber-589197134/" target="_blank" rel="noopener" class="text-heading hover:text-accent transition-colors opacity-60 hover:opacity-100" aria-label="Tobias Weber auf LinkedIn"><LinkedInIcon /></a></h3>
              <p class="text-accent text-sm font-medium">Senior Freelance Full-Stack Developer & IT-Consultant</p>
            </div>
          </div>
          <ul class="space-y-3 text-body">
            <li class="flex gap-3 items-start">
              <span class="text-accent shrink-0">•</span>
              <span>8+ Jahre professioneller Full-Stack-Entwickler
                <ul class="mt-1 ml-4 space-y-1 text-sm">
                  <li>KURZ Digital Solutions (Fürth)</li>
                  <li>TSET (Wien)</li>
                  <li>msg for banking ag (München, Ismaning)</li>
                  <li>SOTA (London)</li>
                </ul>
              </span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent shrink-0">•</span>
              <span>KI-Schulungen für Teams</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent shrink-0">•</span>
              <span>Co-Founder <a href="https://picaboo-app.com" target="_blank" rel="noopener" class="text-accent hover:text-accent-hover underline underline-offset-2">PICABOO</a></span>
            </li>
          </ul>
        </div>

        <!-- Christian -->
        <div class="bg-card border border-divider rounded-2xl p-8">
          <div class="flex items-center gap-5 mb-6">
            <img src={`${import.meta.env.BASE_URL}images/christian-braun.webp`} alt="Christian Braun" class="w-20 h-20 rounded-full object-cover shrink-0" />
            <div>
              <h3 class="text-xl font-bold text-heading flex items-center gap-2">Christian Braun <a href="https://www.linkedin.com/in/hey-christian-braun/" target="_blank" rel="noopener" class="text-heading hover:text-accent transition-colors opacity-60 hover:opacity-100" aria-label="Christian Braun auf LinkedIn"><LinkedInIcon /></a></h3>
              <p class="text-accent text-sm font-medium">Senior Freelance iOS Developer & IT-Consultant</p>
            </div>
          </div>
          <ul class="space-y-3 text-body">
            <li class="flex gap-3 items-start">
              <span class="text-accent shrink-0">•</span>
              <span>8+ Jahre professioneller iOS-Developer
                <ul class="mt-1 ml-4 space-y-1 text-sm">
                  <li>adorsys (Nürnberg)</li>
                  <li>KURZ Digital Solutions (Fürth)</li>
                  <li>IBM (Hamburg, Berlin)</li>
                </ul>
              </span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent shrink-0">•</span>
              <span>Host von <a href="https://open.spotify.com/show/2r1FGvYRkSYq4SmXyVKmnA" target="_blank" rel="noopener" class="text-accent hover:text-accent-hover underline underline-offset-2">Index out of bounds</a>, ein Podcast über Technologie und KI im Entwickleralltag</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent shrink-0">•</span>
              <span>Co-Founder <a href="https://picaboo-app.com" target="_blank" rel="noopener" class="text-accent hover:text-accent-hover underline underline-offset-2">PICABOO</a></span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Persönlicher Block -->
      <div class="bg-card border border-divider rounded-2xl p-8 md:p-10">
        <p class="text-lg text-body leading-relaxed">
          Wir kennen uns seit Jahren, beruflich und privat. Wir schreiben selbst jeden Tag Code mit Coding Agents und erleben, wie sich Softwareentwicklung gerade grundlegend verändert. Das hier ist nicht nur unser Geschäft. Es ist das Thema, über das wir abends beim Bier reden. Wir machen das, weil wir überzeugt sind, dass jedes Entwicklerteam davon profitieren kann. Und weil es uns Spaß macht, dieses Wissen weiterzugeben.
        </p>
      </div>
    </div>
  </section>

  <!-- SEKTION 7: Kontakt -->
  <section id="kontakt" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
