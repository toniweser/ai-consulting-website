---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Braun & Weber — KI-Beratung für den Mittelstand">

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-navy-950/80 backdrop-blur-md border-b border-white/5">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <span class="text-white font-bold text-lg tracking-tight">Braun & Weber KI-Beratung</span>
      <div class="hidden md:flex items-center gap-8">
        <a href="#so-helfen-wir" class="text-sm text-slate-200 hover:text-white transition-colors">So helfen wir</a>
        <a href="#beispiele" class="text-sm text-slate-200 hover:text-white transition-colors">Beispiele</a>
        <a href="#ueber-uns" class="text-sm text-slate-200 hover:text-white transition-colors">Über uns</a>
        <a href="#kontakt" class="text-sm text-white font-semibold bg-accent-500 hover:bg-accent-400 px-5 py-2 rounded-lg transition-colors">Kostenloses Erstgespräch</a>
      </div>
      <!-- Mobile: Hamburger -->
      <button id="menu-toggle" class="md:hidden text-white p-2 -mr-2" aria-label="Menü öffnen">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-navy-950/95 backdrop-blur-md">
      <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
        <a href="#so-helfen-wir" class="text-slate-200 hover:text-white transition-colors mobile-nav-link">So helfen wir</a>
        <a href="#beispiele" class="text-slate-200 hover:text-white transition-colors mobile-nav-link">Beispiele</a>
        <a href="#ueber-uns" class="text-slate-200 hover:text-white transition-colors mobile-nav-link">Über uns</a>
        <a href="#kontakt" class="text-white font-semibold bg-accent-500 hover:bg-accent-400 px-5 py-3 rounded-lg transition-colors text-center mobile-nav-link">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </nav>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => menu.classList.add('hidden'));
    });
  </script>

  <!-- Background Blobs -->
  <div class="blob-container" aria-hidden="true">
    <div class="gradient-blob" id="blob-1"></div>
    <div class="gradient-blob-sm" id="blob-2"></div>
    <div class="gradient-blob" id="blob-3"></div>
  </div>

  <!-- SEKTION 1: Hero -->
  <section class="relative min-h-screen flex items-center pt-20">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-32 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-white leading-tight tracking-tight mb-10">
          Die größte Revolution seit dem Internet.<br />
          <span class="block relative">
            <span class="invisible grid" aria-hidden="true" id="typewriter-sizer"></span>
            <span class="absolute inset-0"><span class="text-transparent bg-clip-text bg-gradient-to-r from-warm-orange via-warm-pink to-accent-400"><span id="typewriter"></span></span><span class="inline-block w-[0.5em] h-[0.9em] bg-white/70 ml-0.5 animate-blink translate-y-[-0.03em]"></span></span>
          </span>
        </h1>

        <style>
          @keyframes blink {
            0%, 100% { opacity: 1; }
            40%, 60% { opacity: 0; }
          }
          .animate-blink {
            animation: blink 1s step-end infinite;
          }
        </style>

        <script>
          const first = 'Zeit, Ihr Team aufzustellen.';
          const rest = [
            'Wer jetzt einsteigt, erklärt es später den anderen.',
            'KI ist kein Hype. Es ist ein Werkzeug.',
            'Machen Sie Ihr Team zum Vorreiter.',
          ];

          // Shuffle rest randomly
          for (let i = rest.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [rest[i], rest[j]] = [rest[j], rest[i]];
          }

          const phrases = [first, ...rest];
          const el = document.getElementById('typewriter');

          // Reserve height for the tallest phrase so content below never shifts
          const sizer = document.getElementById('typewriter-sizer');
          phrases.forEach((phrase) => {
            const line = document.createElement('span');
            line.style.gridArea = '1 / 1';
            line.textContent = phrase;
            sizer.appendChild(line);
          });
          let phraseIndex = 0;
          let charIndex = 0;
          let deleting = false;

          function tick() {
            const current = phrases[phraseIndex];

            if (!deleting) {
              el.textContent = current.slice(0, charIndex + 1);
              charIndex++;

              if (charIndex === current.length) {
                setTimeout(tick, 2500);
                deleting = true;
                return;
              }
              setTimeout(tick, 55 + Math.random() * 40);
            } else {
              el.textContent = current.slice(0, charIndex);
              charIndex--;

              if (charIndex < 0) {
                deleting = false;
                charIndex = 0;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                setTimeout(tick, 400);
                return;
              }
              setTimeout(tick, 25);
            }
          }

          tick();
        </script>
        <p class="text-lg md:text-xl text-slate-200 leading-relaxed max-w-2xl mb-10">
          Code schreiben, Tickets formulieren, Dokumentation pflegen, Angebote erstellen, Kundenanfragen beantworten — Aufgaben, die heute Stunden kosten, erledigt KI in Minuten. Ob Entwicklerteam oder Fachabteilung: Wir zeigen Ihrem Team, wie. In einem Workshop, der auf Ihr Unternehmen zugeschnitten ist.
        </p>
        <a
          href="#kontakt"
          class="inline-block bg-accent-500 hover:bg-accent-400 text-white font-semibold px-8 py-4 rounded-lg text-lg transition-colors"
        >
          Kostenloses Erstgespräch vereinbaren
        </a>
      </div>
    </div>
  </section>

  <!-- SEKTION 2: So helfen wir -->
  <section id="so-helfen-wir" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">So helfen wir Ihrem Unternehmen</h2>
      <p class="text-lg md:text-xl text-slate-200 leading-relaxed max-w-3xl mb-16">
        Viele Unternehmen haben KI ausprobiert — und waren nicht überzeugt. Das ist nachvollziehbar. Aber die Technologie hat sich grundlegend weiterentwickelt. Was vor Monaten noch unzuverlässig war, ist heute ein Werkzeug, auf das sich Ihr Team verlassen kann. Wir zeigen Ihnen, wo es sich für Sie lohnt — und wo nicht.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 hover:bg-white/[0.07] transition-colors">
          <div class="w-12 h-12 bg-accent-500/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Ihr Plan, nicht unserer</h3>
          <p class="text-slate-200 leading-relaxed">
            Am Ende unseres Workshops haben Sie keinen abstrakten Strategiebericht, sondern einen konkreten Fahrplan — zugeschnitten auf Ihre Prozesse, Ihre Branche, Ihr Team.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 hover:bg-white/[0.07] transition-colors">
          <div class="w-12 h-12 bg-accent-500/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Zuverlässig im Arbeitsalltag</h3>
          <p class="text-slate-200 leading-relaxed">
            KI-Tools sind heute robust genug für den täglichen Einsatz in Ihrem Unternehmen. Kein Experiment — ein Werkzeug, das funktioniert.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 hover:bg-white/[0.07] transition-colors">
          <div class="w-12 h-12 bg-accent-500/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.25-8.25-3.286ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Datenschutz inklusive</h3>
          <p class="text-slate-200 leading-relaxed">
            Wir wissen, dass Ihre Daten sensibel sind. Wir zeigen Ihnen DSGVO-konforme Wege, KI sicher einzusetzen — ohne Ihre Daten an Dritte zu geben.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEKTION 3: Konkrete Beispiele -->
  <section id="beispiele" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">Wo KI heute schon hilft</h2>
      <p class="text-lg md:text-xl text-slate-200 leading-relaxed max-w-3xl mb-16">
        Keine Theorie — das sind typische Szenarien, die wir in unseren Workshops mit Unternehmen erarbeiten.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <p class="text-accent-400 text-sm font-semibold mb-2">Software-Entwicklung</p>
          <h3 class="text-lg font-bold text-white mb-3">Entwickler, die mit KI schneller liefern</h3>
          <p class="text-slate-200 leading-relaxed">
            Code schreiben, Reviews beschleunigen, Tests generieren, Bugs debuggen — mit Copilot, Claude Code und Cursor arbeiten Ihre Entwickler messbar produktiver. Am eigenen Code, nicht an Spielbeispielen.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <p class="text-accent-400 text-sm font-semibold mb-2">Product & Projektmanagement</p>
          <h3 class="text-lg font-bold text-white mb-3">Bessere Tickets, schnellere Dokumentation</h3>
          <p class="text-slate-200 leading-relaxed">
            User Stories mit Akzeptanzkriterien in Minuten statt Stunden. Release Notes aus Git-History generieren. Sprint-Dokumentation automatisieren. Ihre POs und Scrum Master werden zum Multiplikator.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <p class="text-accent-400 text-sm font-semibold mb-2">Vertrieb & Angebotswesen</p>
          <h3 class="text-lg font-bold text-white mb-3">Angebote in Minuten statt Stunden</h3>
          <p class="text-slate-200 leading-relaxed">
            Ihr Vertrieb erstellt individuelle Angebote auf Basis vergangener Aufträge, Preislisten und Kundenanforderungen. KI reduziert den Aufwand pro Angebot deutlich.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <p class="text-accent-400 text-sm font-semibold mb-2">Kundenservice</p>
          <h3 class="text-lg font-bold text-white mb-3">Anfragen schneller beantworten</h3>
          <p class="text-slate-200 leading-relaxed">
            Wiederkehrende Kundenanfragen per E-Mail oder Ticket? KI erstellt Antwortentwürfe, die Ihr Team nur noch prüft und abschickt — Reaktionszeit halbiert.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <p class="text-accent-400 text-sm font-semibold mb-2">Buchhaltung & Verwaltung</p>
          <h3 class="text-lg font-bold text-white mb-3">Belege und Dokumente automatisch verarbeiten</h3>
          <p class="text-slate-200 leading-relaxed">
            Rechnungen erfassen, kategorisieren, zuordnen — Aufgaben, die Ihre Buchhaltung Stunden kosten. KI übernimmt die Vorarbeit, Ihr Team kontrolliert nur noch.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <p class="text-accent-400 text-sm font-semibold mb-2">Marketing & Kommunikation</p>
          <h3 class="text-lg font-bold text-white mb-3">Content erstellen, der nach Ihnen klingt</h3>
          <p class="text-slate-200 leading-relaxed">
            Newsletter, Social-Media-Posts, Produktbeschreibungen — KI erstellt Entwürfe in Ihrem Ton. Ihr Marketing-Team wird produktiver, ohne an Qualität zu verlieren.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEKTION 4: Ablauf -->
  <section class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">So läuft es ab</h2>
      <p class="text-lg md:text-xl text-slate-200 leading-relaxed max-w-3xl mb-16">
        Kein langes Drumherum. Drei Schritte, dann wissen Sie, wo KI Ihnen hilft.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="text-accent-400 text-4xl font-extrabold mb-4">1</div>
          <h3 class="text-lg font-bold text-white mb-3">Erstgespräch (kostenlos)</h3>
          <p class="text-slate-200 leading-relaxed">
            30 Minuten, telefonisch oder per Video. Wir hören zu, stellen Fragen und finden heraus, wo bei Ihnen die größten Hebel liegen.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="text-accent-400 text-4xl font-extrabold mb-4">2</div>
          <h3 class="text-lg font-bold text-white mb-3">Workshop vor Ort oder remote</h3>
          <p class="text-slate-200 leading-relaxed">
            Ein halber bis ganzer Tag mit Ihrem Team. Für Entwickler: Hands-on am eigenen Code mit Copilot, Claude Code und Cursor. Für Product-Teams: KI-gestützte Tickets, Doku und Workflows. Für Fachabteilungen: KI im Arbeitsalltag.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="text-accent-400 text-4xl font-extrabold mb-4">3</div>
          <h3 class="text-lg font-bold text-white mb-3">Ihr Fahrplan zum Mitnehmen</h3>
          <p class="text-slate-200 leading-relaxed">
            Sie bekommen einen konkreten Plan: Welche Tools, welche Prozesse, welche nächsten Schritte. Kein Berater-Deutsch, sondern Klartext.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEKTION 5: Wer wir sind -->
  <section id="ueber-uns" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">Wer wir sind</h2>
      <p class="text-lg md:text-xl text-slate-200 leading-relaxed max-w-3xl mb-16">
        Wir sind selbst Entwickler und arbeiten täglich produktiv mit Claude Code, Copilot und Cursor. Wir verbinden diese Erfahrung mit praxisnaher Begleitung für Ihr Team — ob Engineering, Product oder Fachabteilung.
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Tobias -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-5 mb-6">
            <img src={`${import.meta.env.BASE_URL}images/tobias-weber.jpg`} alt="Tobias Weber" class="w-20 h-20 rounded-full object-cover shrink-0" />
            <div>
              <h3 class="text-xl font-bold text-white">Tobias Weber</h3>
              <p class="text-accent-400 text-sm font-medium">IT-Consultant & KI-Trainer</p>
            </div>
          </div>
          <ul class="space-y-3 text-slate-200">
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>8+ Jahre Erfahrung in der IT-Beratung für Unternehmen</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>KI-Schulungen für Teams — von der Führungsebene bis zur Fachabteilung</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>msg for banking ag, KURZ Digital Solutions</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>Co-Founder <a href="https://picaboo-app.com" target="_blank" rel="noopener" class="text-accent-400 hover:text-accent-300 underline underline-offset-2">PICABOO</a></span>
            </li>
          </ul>
        </div>

        <!-- Christian -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-5 mb-6">
            <img src={`${import.meta.env.BASE_URL}images/christian-braun.webp`} alt="Christian Braun" class="w-20 h-20 rounded-full object-cover shrink-0" />
            <div>
              <h3 class="text-xl font-bold text-white">Christian Braun</h3>
              <p class="text-accent-400 text-sm font-medium">IT-Consultant & KI-Trainer</p>
            </div>
          </div>
          <ul class="space-y-3 text-slate-200">
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>8+ Jahre Erfahrung in der IT-Beratung für Unternehmen</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>Host von <a href="https://open.spotify.com/show/2r1FGvYRkSYq4SmXyVKmnA" target="_blank" rel="noopener" class="text-accent-400 hover:text-accent-300 underline underline-offset-2">Index out of bounds</a> — Podcast über Technologie und KI im Alltag</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>IBM, KURZ Digital Solutions</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-400 mt-1 shrink-0">—</span>
              <span>Co-Founder <a href="https://picaboo-app.com" target="_blank" rel="noopener" class="text-accent-400 hover:text-accent-300 underline underline-offset-2">PICABOO</a></span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Persönlicher Block -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10">
        <p class="text-lg text-slate-200 leading-relaxed">
          Wir kennen uns seit Jahren — beruflich und privat. Wir schreiben selbst jeden Tag Code mit KI-Unterstützung und wissen, was funktioniert und was nicht. Diese Erfahrung bringen wir gezielt in unsere Workshops ein — für Entwicklerteams, Product Owner und Fachabteilungen gleichermaßen.
        </p>
      </div>
    </div>
  </section>

  <!-- SEKTION 6: Kontakt -->
  <section id="kontakt" class="relative py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6 text-center">Kostenloses Erstgespräch</h2>
        <p class="text-lg text-slate-200 leading-relaxed text-center mb-12">
          30 Minuten, unverbindlich, ohne Verkaufsdruck. Wir hören zu und sagen Ihnen ehrlich, ob und wo KI Ihnen helfen kann. Wir melden uns innerhalb von 24 Stunden.
        </p>

        <form id="contact-form" class="space-y-6">
          <!-- E-Mail (Pflicht) -->
          <div>
            <label for="email" class="block text-sm font-medium text-slate-200 mb-2">E-Mail-Adresse *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white placeholder-slate-300 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500 transition-colors"
              placeholder="ihre@email.de"
            />
          </div>

          <!-- Unternehmen -->
          <div>
            <label for="company" class="block text-sm font-medium text-slate-200 mb-2">Unternehmen</label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white placeholder-slate-300 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500 transition-colors"
              placeholder="Firmenname"
            />
          </div>

          <!-- Interessen -->
          <fieldset>
            <legend class="block text-sm font-medium text-slate-200 mb-3">Was interessiert Sie?</legend>
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 cursor-pointer hover:bg-white/[0.07] transition-colors has-[:checked]:border-accent-500/50 has-[:checked]:bg-accent-500/10">
                <div class="flex items-center gap-3">
                  <input type="checkbox" name="interest" value="KI-Workshop" class="accent-accent-500 w-4 h-4 shrink-0" />
                  <span class="text-sm text-white font-medium">KI-Workshop</span>
                </div>
                <p class="text-xs text-slate-400 mt-1 ml-7">Praktisches Training für Ihr Team</p>
              </label>
              <label class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 cursor-pointer hover:bg-white/[0.07] transition-colors has-[:checked]:border-accent-500/50 has-[:checked]:bg-accent-500/10">
                <div class="flex items-center gap-3">
                  <input type="checkbox" name="interest" value="Strategieberatung" class="accent-accent-500 w-4 h-4 shrink-0" />
                  <span class="text-sm text-white font-medium">Strategieberatung</span>
                </div>
