  <!-- Blob interaction (progressive enhancement) -->
  <script>
    const blobs = document.querySelectorAll('.gradient-blob, .gradient-blob-sm');
    const isTouch = window.matchMedia('(pointer: coarse)').matches;
    const vw = window.innerWidth;
    const vh = window.innerHeight;

    if (!isTouch) {
      blobs.forEach(blob => blob.style.animation = 'none');
    }

    const config = [
      { startX: 0, startY: 0, speed: 0.025, driftRadius: 120, driftSpeed: 0.0008, mouseWeight: 0.35 },
      { startX: 0, startY: 0, speed: 0.015, driftRadius: 180, driftSpeed: 0.0005, mouseWeight: 0.2  },
      { startX: 0, startY: 0, speed: 0.01,  driftRadius: 150, driftSpeed: 0.0006, mouseWeight: 0.15 },
    ];

    const blobRects = Array.from(blobs).map(b => {
      const r = b.getBoundingClientRect();
      return { cx: r.left + r.width / 2, cy: r.top + r.height / 2 };
    });

    const state = config.map(c => ({
      x: c.startX, y: c.startY,
      targetX: c.startX, targetY: c.startY,
      homeX: c.startX, homeY: c.startY,
    }));

    let mouseX = vw / 2;
    let mouseY = vh / 2;
    let time = 0;

    function animate() {
      time++;
      state.forEach((s, i) => {
        const c = config[i];
        const phase = i * 2.1;
        const driftX = Math.sin(time * c.driftSpeed + phase) * c.driftRadius
                     + Math.cos(time * c.driftSpeed * 0.7 + phase * 1.3) * c.driftRadius * 0.5;
        const driftY = Math.cos(time * c.driftSpeed * 0.9 + phase * 0.8) * c.driftRadius
                     + Math.sin(time * c.driftSpeed * 0.6 + phase * 1.7) * c.driftRadius * 0.4;

        if (isTouch) {
          s.targetX = driftX;
          s.targetY = driftY;
        } else {
          const pullX = mouseX - blobRects[i].cx;
          const pullY = mouseY - blobRects[i].cy;
          s.targetX = driftX + pullX * c.mouseWeight;
          s.targetY = driftY + pullY * c.mouseWeight;
        }

        s.x += (s.targetX - s.x) * c.speed;
        s.y += (s.targetY - s.y) * c.speed;
        blobs[i].style.transform = `translate(${s.x}px, ${s.y}px) translateZ(0)`;
      });
      requestAnimationFrame(animate);
    }

    if (!isTouch) {
      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });
      animate();
    }
  </script>

